# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
/playwright-report/
/test-results/
/tests/e2e/.auth/
/tests/e2e/.env.e2e

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.local.example
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

.vercel

# operator-data artifacts produced by scripts/audit-* and scripts/apply-*
# (TSVs contain per-operator event_id / event_name; not for the repo)
*-proposals.tsv
*-audit.tsv
weather-location-audit.tsv
start-times-audit.tsv
