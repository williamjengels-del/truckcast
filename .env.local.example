# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Stripe
STRIPE_SECRET_KEY=your_stripe_secret_key
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret
STRIPE_STARTER_MONTHLY_PRICE_ID=price_xxx
STRIPE_STARTER_ANNUAL_PRICE_ID=price_xxx
STRIPE_PRO_MONTHLY_PRICE_ID=price_xxx
STRIPE_PRO_ANNUAL_PRICE_ID=price_xxx
STRIPE_PREMIUM_MONTHLY_PRICE_ID=price_xxx
STRIPE_PREMIUM_ANNUAL_PRICE_ID=price_xxx

# Square POS (OAuth 2.0)
SQUARE_APP_ID=your_square_app_id
SQUARE_APP_SECRET=your_square_app_secret

# Clover POS (OAuth 2.0)
CLOVER_APP_ID=your_clover_app_id
CLOVER_APP_SECRET=your_clover_app_secret
CLOVER_API_BASE_URL=https://api.clover.com
CLOVER_WEB_BASE_URL=https://www.clover.com

# SumUp POS (OAuth 2.0)
SUMUP_CLIENT_ID=your_sumup_client_id
SUMUP_CLIENT_SECRET=your_sumup_client_secret

# Email (Resend)
RESEND_API_KEY=re_xxxxxxxx
EMAIL_FROM=VendCast <hello@vendcast.co>

# Anthropic (AI chat widget — Pro/Premium gated)
# If unset, the chat widget does not render and /api/chat returns 503.
ANTHROPIC_API_KEY=sk-ant-xxxxxxxx

# Tier-B chatbot operational controls. The endpoint
# (/api/chat-v2) is Premium-only by tier; these knobs let ops adjust
# behavior without a code deploy.
#
# CHAT_V2_DISABLED=1  → kill switch. /api/chat-v2 returns 503 + a
#                      maintenance message. Widget displays it
#                      verbatim. Use case: cost spike or model
#                      regression while we investigate.
# CHAT_V2_MONTHLY_CAP_CENTS  → soft per-operator monthly cost cap.
#                      Default 1000 (=$10). Smaller values during
#                      preview/test; raise once usage stabilizes.
CHAT_V2_DISABLED=
CHAT_V2_MONTHLY_CAP_CENTS=

# Cron (authenticates Vercel cron jobs hitting /api/cron/* routes).
# Also used by /api/push/send to authenticate internal push calls.
CRON_SECRET=generate_a_long_random_string

# Web Push (Phase 8.2). Generate a fresh keypair with:
#   npx web-push generate-vapid-keys
# Paste the "Public Key" into NEXT_PUBLIC_VAPID_PUBLIC_KEY (browser reads it
# to subscribe) and the "Private Key" into VAPID_PRIVATE_KEY (server only).
# VAPID_SUBJECT is a mailto: URL so push services can contact us on abuse.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=B_replace_with_public_key
VAPID_PRIVATE_KEY=replace_with_private_key
VAPID_SUBJECT=mailto:hello@vendcast.co

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
